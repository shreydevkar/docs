  "keyFeatures": [
    "Natural-language chat to build and edit spreadsheets",
    "Multi-provider LLM support: Gemini, Claude, Groq, OpenRouter",
    "Preview/apply flow — review AI writes before committing",
    "Chain mode — agent auto-applies multi-step plans end-to-end",
    "Formula synthesis with collision-safe cell placement",
    "User-defined macros composed from built-in primitives",
    "Chart overlays (bar, line, pie) rendered via Chart.js",
    "Preset templates: DCF, Budget, Break-Even, Loan Amortization, Income Statement",
    "Cell locking to protect read-only ranges from AI edits",
    "Workbook persistence with .gridos file import/export"
  ],
  "publicApiSurface": [
    "POST /agent/chat",
    "POST /agent/apply",
    "POST /agent/chat/chain",
    "POST /agent/write",
    "POST /grid/cell",
    "POST /grid/range",
